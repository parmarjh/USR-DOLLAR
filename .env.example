# ===========================================
# Multi-Agent Research System Configuration
# ===========================================
# Copy this file to .env and fill in your values

# LLM Provider: "gemini", "openai", "ollama", or "openrouter"
LLM_PROVIDER=openrouter

# ── OpenRouter API (Recommended - Access 100+ models) ──
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Popular models on OpenRouter:
#   google/gemini-2.0-flash-001    (fast, free tier)
#   anthropic/claude-3.5-sonnet    (premium)
#   meta-llama/llama-3-70b-instruct (open-source)
#   mistralai/mistral-large        (balanced)
#   openai/gpt-4o                  (premium)

# ── Google Gemini (Free tier: https://aistudio.google.com/apikey) ──
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (https://platform.openai.com/api-keys) ──
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4

# ── Ollama (Local, Free - https://ollama.com) ──
# OLLAMA_MODEL=llama3

# ── System Config ──
DATABASE_URL=sqlite:///research_metadata.db
VECTOR_DB_PATH=./faiss_research_db
PDF_FOLDER=./my_papers
EMBEDDING_MODEL=all-MiniLM-L6-v2
